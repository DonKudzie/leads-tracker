{
  "manifest_version": 3,
  "name": "Leads Tracker",
  "version": "1.0.0",
  "description": "Leads tracker extension",
  
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage"
  ],
  
  "host_permissions": [
    "<all_urls>"
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "Leads Tracker",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }}
